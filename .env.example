# Development (default)
# DJANGO_SETTINGS_MODULE=config.settings.develop
# DEBUG=True
# ALLOWED_HOSTS=127.0.0.1,localhost,backend
# CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Production (DigitalOcean)
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=change-me-in-production
DEBUG=False
SECURE_SSL_REDIRECT=False

ALLOWED_HOSTS=example.com,www.example.com,DROPLET_IP,127.0.0.1,localhost,backend
CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# PostgreSQL (Docker)
POSTGRES_DB=vetclinic
POSTGRES_USER=vetclinic
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://vetclinic:change-me@db:5432/vetclinic

# Local dev server (scripts/dev-server.sh)
# DEV_HOST=127.0.0.1
# DEV_PORT=8000
# DEV_RELOAD=0
# DEV_WATCH=1
